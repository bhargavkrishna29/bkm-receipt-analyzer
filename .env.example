# .env.example — copy to .env for local development

# ── Gemini (server-side only — never exposed to browser) ───────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Rate limiting ──────────────────────────────────────────────────────────
# RATE_LIMIT_MAX     — max requests per IP per window (default: 10)
# RATE_LIMIT_WINDOW_MS — window in ms (default: 3600000 = 1 hour)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=3600000

# ── Firebase client config ─────────────────────────────────────────────────
# Prefixed with  so Next.js includes them in the browser bundle.
# These values are safe to expose (they're embedded in the HTML anyway).
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_DATABASE_ID=spendwise